# Google AdSense configuration
# Copy this file to .env.local and fill in your actual IDs.
# After approval: set these same vars on Vercel (Project Settings → Environment Variables).

# Publisher ID from AdSense (ca-pub-XXXXXXXXXXXXXXXX)
VITE_ADSENSE_CLIENT=

# Ad Unit Slot IDs (created per ad unit in AdSense dashboard)
VITE_ADSENSE_SLOT_MIDDLE=
VITE_ADSENSE_SLOT_BOTTOM=
